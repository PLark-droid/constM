{
  "name": "constm",
  "version": "0.1.0",
  "description": "Autonomous development powered by Miyabi Framework & Agentic OS",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "generate:dashboard": "tsx scripts/generate-dashboard-data.ts",
    "lark:auth-test": "tsx scripts/lark-auth-test.ts",
    "provision:base": "tsx scripts/provision/index.ts",
    "provision:seed": "tsx scripts/provision/seed.ts"
  },
  "keywords": [
    "miyabi",
    "autonomous-development",
    "agentic-os",
    "shikigaku"
  ],
  "author": "PLark-droid",
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "dotenv": "^17.3.1",
    "miyabi": "^0.19.0"
  }
}
